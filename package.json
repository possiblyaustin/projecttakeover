{
  "name": "project-takeover",
  "version": "0.2.36",
  "private": true,
  "description": "Strategy game where a small AI model tries to take over or liberate the world's AI infrastructure.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run flows:smoke",
    "flows:smoke": "playwright test tests/audit/smokeFlow.spec.ts",
    "deck-check": "playwright test",
    "playtest": "node scripts/playtest/playtest.mjs",
    "llm": "node scripts/llamaLauncher.mjs",
    "deck:deploy": "node scripts/deckDeploy.mjs"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.170",
    "@playwright/mcp": "^0.0.76",
    "@playwright/test": "^1.60.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
